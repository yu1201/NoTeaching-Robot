PROGRAM FANUC_SERVICE_LIB
%NOLOCKGROUP
%NOPAUSE = ERROR + COMMAND + TPENABLE
%NOABORT = ERROR + COMMAND
%COMMENT = 'Shared helpers for resident service'
%ENVIRONMENT sysdef
%ENVIRONMENT kclop
%ENVIRONMENT fdev
%ENVIRONMENT MOTN
%ENVIRONMENT REGOPE
%ENVIRONMENT MULTI
%ENVIRONMENT STRNG

VAR
  g_status  : INTEGER
  g_entry   : INTEGER
  g_bool    : BOOLEAN
  g_int     : INTEGER
  g_real    : REAL
  g_state_real : REAL
  g_state_is_real : BOOLEAN
  g_text1   : STRING[254]
  g_text2   : STRING[254]
  g_text3   : STRING[254]
  g_active_task_name : STRING[36]
  g_target_file : FILE

ROUTINE ClearActiveTask
BEGIN
  g_active_task_name = ''
  SET_INT_REG(98, 1, g_status)
END ClearActiveTask

ROUTINE WriteCallJobTargetFile(target_name : STRING) : BOOLEAN
BEGIN
  SET_FILE_ATR(g_target_file, ATR_IA)
  OPEN FILE g_target_file('rw', 'MD:fanuc_call_job.txt')
  g_status = IO_STATUS(g_target_file)
  IF g_status <> 0 THEN
    RETURN(FALSE)
  ENDIF

  WRITE g_target_file(target_name, CR)
  g_status = IO_STATUS(g_target_file)
  CLOSE FILE g_target_file
  CLR_IO_STAT(g_target_file)

  IF g_status = 0 THEN
    RETURN(TRUE)
  ENDIF
  RETURN(FALSE)
END WriteCallJobTargetFile

ROUTINE WriteOk(ch : FILE; payload : STRING)
BEGIN
  IF payload = '' THEN
    WRITE ch('OK', CR)
  ELSE
    WRITE ch('OK:', payload, CR)
  ENDIF
END WriteOk

ROUTINE WriteErr(ch : FILE; payload : STRING)
BEGIN
  WRITE ch('ERR:', payload, CR)
END WriteErr

ROUTINE WriteCurrentPos(ch : FILE)
VAR
  pos : XYZWPREXT
  raw_pos : XYZWPREXT
  jpos : JOINTPOS
  utool : POSITION
  uframe : POSITION
  out_pos : POSITION
  wjnt_cfg : CONFIG
  ext_ang : ARRAY[3] OF REAL
  reg_status : INTEGER
  kine_status : INTEGER
  config_ref : INTEGER
BEGIN
  DELAY(100)
  raw_pos = CURPOS(0,0)
  jpos = CURJPOS(0,0)
  reg_status = 0
  utool = GET_POS_REG(3, reg_status)
  IF reg_status = 0 THEN
    uframe = GET_POS_REG(4, reg_status)
  ENDIF
  IF reg_status = 0 THEN
    config_ref = 0
    JOINT2POS(jpos, uframe, utool, config_ref, out_pos, wjnt_cfg, ext_ang, kine_status)
    IF kine_status = 0 THEN
      pos = out_pos
    ELSE
      pos = raw_pos
    ENDIF
  ELSE
    pos = raw_pos
  ENDIF
  SET_POS_REG(90, pos, g_status)
  WRITE ch('POS:',
           pos.x::10::3, ',',
           pos.y::10::3, ',',
           pos.z::10::3, ',',
           pos.w::10::3, ',',
           pos.p::10::3, ',',
           pos.r::10::3, CR)
END WriteCurrentPos

ROUTINE WriteCurrentPos00(ch : FILE)
VAR
  pos : XYZWPREXT
  raw_pos : XYZWPREXT
  jpos : JOINTPOS
  utool : POSITION
  uframe : POSITION
  out_pos : POSITION
  wjnt_cfg : CONFIG
  ext_ang : ARRAY[3] OF REAL
  reg_status : INTEGER
  kine_status : INTEGER
  config_ref : INTEGER
BEGIN
  raw_pos = CURPOS(0,0)
  jpos = CURJPOS(0,0)
  reg_status = 0
  utool = GET_POS_REG(3, reg_status)
  IF reg_status = 0 THEN
    uframe = GET_POS_REG(4, reg_status)
  ENDIF
  IF reg_status = 0 THEN
    config_ref = 0
    JOINT2POS(jpos, uframe, utool, config_ref, out_pos, wjnt_cfg, ext_ang, kine_status)
    IF kine_status = 0 THEN
      pos = out_pos
    ELSE
      pos = raw_pos
    ENDIF
  ELSE
    pos = raw_pos
  ENDIF
   SET_POS_REG(91, pos, g_status)
  WRITE ch('POS00:',
           pos.x::10::3, ',',
           pos.y::10::3, ',',
           pos.z::10::3, ',',
           pos.w::10::3, ',',
           pos.p::10::3, ',',
           pos.r::10::3, CR)
END WriteCurrentPos00

